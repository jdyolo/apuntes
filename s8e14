using UnityEngine;

public class gamemanager : MonoBehaviour
{
    void Start()
    {
        int energia = 10;

        for (int i = 0; i < 20; i++)
        {
            energia--;

            Debug.Log("Energia: " + energia);

            if (energia <= 0)
            {
                Debug.Log("Energia agotada");
                break;
            }
        }
    }
}
